@page "/admin/producto/editar/{Id:int}"
@page "/editarproducto/{Id:int}"

@using System.Globalization
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Forms

@inject HttpClient Http
@inject NavigationManager Nav
@inject MauiBlazorDelivery.Services.AuthService Auth
@inject MauiBlazorDelivery.Services.ImagenCacheService ImagenCache

<h2 class="mb-3">Editar Producto</h2>

@if (!string.IsNullOrEmpty(_loadError))
{
    <div class="alert alert-danger">@_loadError</div>
}

@if (_mostrarToast)
{
    <div class="app-toast">
        <div class="app-toast-body">
            <div class="app-toast-title">@_toastTitulo</div>
            @_toastTexto
        </div>
        <button class="app-toast-close" @onclick="CerrarToast">×</button>
    </div>
}

@if (Cargando)
{
    <Spinner />
}
else
{
    @* form con padding inferior global (.edit-page) *@
    <EditForm class="edit-page" Model="Model" OnValidSubmit="ConfirmarAntesDeGuardar">
        <DataAnnotationsValidator />
        <ValidationSummary />

        @* Nombre *@
        <div class="mb-3">
            <label class="form-label">Nombre</label>
            <InputText class="form-control" @bind-Value="Model.NombreProducto" />
            <ValidationMessage For="@(() => Model.NombreProducto)" />
        </div>

        @* Descripción *@
        <div class="mb-3">
            <label class="form-label">Descripción</label>
            <InputTextArea class="form-control" @bind-Value="Model.Descripcion" />
            <ValidationMessage For="@(() => Model.Descripcion)" />
        </div>

        @* Precio *@
        <div class="mb-3">
            <label class="form-label">Precio</label>
            <InputNumber class="form-control" @bind-Value="Model.Precio" step="0.01" />
            <ValidationMessage For="@(() => Model.Precio)" />
            <small class="text-muted">Valor actual: @Model.Precio?.ToString("F2")</small>
        </div>

        @* Imagen actual *@
        @if (!string.IsNullOrWhiteSpace(ImagenActualUrl))
        {
            <div class="mb-3">
                <label class="form-label">Imagen actual</label><br />
                <!-- uso .img-preview global, sin inline styles -->
                <img src="@ImagenActualUrl" alt="Imagen actual" class="img-thumbnail img-preview" />
            </div>
        }

        @* Cambiar imagen *@
        <div class="mb-3">
            <label class="form-label">Cambiar imagen (opcional)</label>
            <div>
                <button type="button" class="btn btn-pill btn-grad-file" @onclick="SeleccionarImagenAsync">Elegir archivo</button>
                <span class="ms-2 align-middle">@TextoArchivoSeleccionado</span>
            </div>
            @if (!string.IsNullOrEmpty(PreviewDataUrl))
            {
                <img src="@PreviewDataUrl" class="img-thumbnail mt-2 img-preview" />
            }
        </div>

        @* Acciones *@
        <div class="mt-4 d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-pill btn-grad-guardar" disabled="@Guardando">Guardar cambios</button>
            <button type="button" class="btn btn-pill btn-grad-cancelar" @onclick="Cancelar">Cancelar</button>
        </div>

        @* Cerrar sesión *@
        <div class="mt-5">
            <button type="button" class="btn btn-gradient-red" @onclick="CerrarSesion">Cerrar sesión</button>
        </div>
    </EditForm>
}

@* ---------- Modal de confirmación (reutilizable, sin estilos inline) ---------- *@
@if (MostrarConfirmacion)
{
    <div class="modal-backdrop-custom" @onclick="CerrarModal"></div>
    <div class="modal-custom" role="dialog" aria-modal="true" @onclick:stopPropagation="true">
        <div class="modal-header">
            <h5 class="modal-title">Confirmar guardado</h5>
        </div>
        <div class="modal-body">
            <p>¿Estás seguro que quieres guardar los cambios?</p>
            <small class="text-muted d-block">Precio a guardar: @Model.Precio?.ToString("F2")</small>
        </div>
        <div class="modal-footer">
            <button class="btn btn-pill btn-grad-cancelar-modal" @onclick="CerrarModal">No, cancelar</button>
            <button class="btn btn-pill btn-grad-confirmar" @onclick="GuardarYVolverAsync">Sí, confirmar</button>
        </div>
    </div>
}

@code {
    // -------- Parámetro --------
    [Parameter] public int Id { get; set; }

    // -------- VM --------
    public class ProductoEditVm
    {
        public int IdProducto { get; set; }
        [System.ComponentModel.DataAnnotations.Required] public string? NombreProducto { get; set; }
        [System.ComponentModel.DataAnnotations.Required] public string? Descripcion { get; set; }
        [System.ComponentModel.DataAnnotations.Range(0.01, double.MaxValue)] public decimal? Precio { get; set; }
        public string? Imagen { get; set; }
    }

    // -------- Estado --------
    private ProductoEditVm Model = new();
    private bool Cargando = true;
    private bool Guardando = false;
    private bool MostrarConfirmacion = false;
    private string? _loadError;

    private bool _mostrarToast;
    private string _toastTitulo = "";
    private string _toastTexto = "";
    private System.Timers.Timer? _toastTimer;
    private string? ImagenActualUrl;
    private string? PreviewDataUrl;
    private byte[]? _imagenBytes;
    private string? _imagenNombre;
    private string? _imagenContentType;

    private string NombreArchivoSeleccionado = string.Empty;
    private string TextoArchivoSeleccionado =>
        string.IsNullOrWhiteSpace(NombreArchivoSeleccionado)
            ? "No se eligió ningún archivo"
            : NombreArchivoSeleccionado;

    // -------- Ciclo de vida --------
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var prod = await Http.GetFromJsonAsync<ProductoEditVm>($"api/producto/{Id}");
            if (prod is null)
            {
                _loadError = "Producto no encontrado.";
                return;
            }

            Model = prod;
            ImagenActualUrl = await ImagenCache.GetDataUrlAsync(prod.Imagen);
        }
        catch (Exception ex)
        {
            _loadError = $"Error al cargar el producto: {ex.Message}";
        }
        finally
        {
            Cargando = false;
        }
    }

    // -------- Eventos UI --------
    private async Task SeleccionarImagenAsync()
    {
        byte[]? bytes = null;
        string? nombre = null;
        string? contentType = null;

        try
        {
            await MainThread.InvokeOnMainThreadAsync(async () =>
            {
                var result = await MediaPicker.Default.PickPhotoAsync();
                if (result is null) return;

                nombre = result.FileName;
                contentType = result.ContentType ?? "image/jpeg";

                using var stream = await result.OpenReadAsync();
                using var ms = new MemoryStream();
                await stream.CopyToAsync(ms);
                bytes = ms.ToArray();
            });

            if (bytes is null) return;

            if (bytes.Length == 0)
            {
                MostrarToast("Error", "No se pudo leer la imagen. Intentá con otra.");
                return;
            }

            _imagenBytes = bytes;
            _imagenNombre = nombre;
            _imagenContentType = contentType ?? "image/jpeg";
            NombreArchivoSeleccionado = nombre ?? "imagen";
            PreviewDataUrl = $"data:{_imagenContentType};base64,{Convert.ToBase64String(_imagenBytes)}";
        }
        catch (Exception ex)
        {
            MostrarToast("Error", $"No se pudo seleccionar la imagen: {ex.Message}");
            _imagenBytes = null;
            PreviewDataUrl = null;
            NombreArchivoSeleccionado = string.Empty;
        }
        StateHasChanged();
    }

    private void ConfirmarAntesDeGuardar(EditContext _)
    {
        MostrarConfirmacion = true;
        StateHasChanged();
    }

    private void CerrarModal()
    {
        MostrarConfirmacion = false;
        StateHasChanged();
    }

    private async Task GuardarYVolverAsync()
    {
        CerrarModal();
        var ok = await GuardarInternoAsync();
        if (ok) Nav.NavigateTo("/gestioncatalogo?ok=1");
    }

    // -------- Guardado --------
    private async Task<bool> GuardarInternoAsync()
    {
        if (Guardando) return false;

        Guardando = true;

        try
        {
            HttpResponseMessage resp;

            if (_imagenBytes is null || _imagenBytes.Length == 0)
            {
                // Sin imagen: JSON
                var payload = new
                {
                    IdProducto = Model.IdProducto,
                    NombreProducto = Model.NombreProducto ?? "",
                    Descripcion = Model.Descripcion ?? "",
                    Precio = Model.Precio ?? 0m,
                    Imagen = Model.Imagen
                };

                resp = await Http.PutAsJsonAsync($"api/producto/{Id}", payload);
            }
            else
            {
                // Con imagen: multipart/form-data
                using var form = new MultipartFormDataContent();

                var precioString = (Model.Precio ?? 0m).ToString("F2", CultureInfo.InvariantCulture);

                form.Add(new StringContent(Model.IdProducto.ToString()), "IdProducto");
                form.Add(new StringContent(Model.NombreProducto ?? ""), "NombreProducto");
                form.Add(new StringContent(Model.Descripcion ?? ""), "Descripcion");
                form.Add(new StringContent(precioString), "Precio");

                var fileName = Path.GetFileName(_imagenNombre ?? "upload.jpg");
                if (string.IsNullOrWhiteSpace(fileName)) fileName = "upload.jpg";

                var fileContent = new ByteArrayContent(_imagenBytes);
                fileContent.Headers.ContentType = new MediaTypeHeaderValue(_imagenContentType ?? "image/jpeg");
                form.Add(fileContent, "ImagenArchivo", fileName);

                resp = await Http.PutAsync($"api/producto/{Id}/con-imagen", form);
            }

            if (!resp.IsSuccessStatusCode)
            {
                var detalle = await resp.Content.ReadAsStringAsync();
                MostrarToast("Error", $"No se pudo guardar. Código {resp.StatusCode}.");
                Console.WriteLine($"[CLIENT] Error response: {detalle}");
                return false;
            }

            var actualizado = await resp.Content.ReadFromJsonAsync<ProductoEditVm>();
            if (actualizado is not null)
            {
                Console.WriteLine($"[CLIENT] Respuesta del servidor - Precio: {actualizado.Precio}");
                Model = actualizado;
                ImagenActualUrl = await ImagenCache.GetDataUrlAsync(actualizado.Imagen);
                PreviewDataUrl = null;
                _imagenBytes = null;
                _imagenNombre = null;
                _imagenContentType = null;
                NombreArchivoSeleccionado = string.Empty;
            }

            MostrarToast("Éxito", "Producto actualizado correctamente.");
            return true;
        }
        catch (Exception ex)
        {
            MostrarToast("Error", $"Error al guardar: {ex.Message}");
            Console.WriteLine($"[CLIENT] Exception: {ex}");
            return false;
        }
        finally
        {
            Guardando = false;
            StateHasChanged();
        }
    }

    private void MostrarToast(string titulo, string texto)
    {
        _toastTitulo = titulo;
        _toastTexto = texto;
        _mostrarToast = true;
        StateHasChanged();
        _toastTimer?.Stop();
        _toastTimer = new System.Timers.Timer(3000) { AutoReset = false };
        _toastTimer.Elapsed += (_, __) => { _mostrarToast = false; InvokeAsync(StateHasChanged); };
        _toastTimer.Start();
    }

    private void CerrarToast() { _mostrarToast = false; _toastTimer?.Stop(); }

    // -------- Navegación --------
    private void Cancelar() => Nav.NavigateTo("/gestioncatalogo");

    private void CerrarSesion()
    {
        Auth.Logout();
        Nav.NavigateTo("/login", true);
    }
}
