@page "/gestionrepartidores"
@inject NavigationManager Nav
@inject MauiBlazorDelivery.Services.AuthService Auth
@inject MauiBlazorDelivery.Services.RepartidorService RepartidorSvc
@inject MauiBlazorDelivery.Services.AdminService AdminSvc
@using MauiBlazorDelivery.Services
@implements IDisposable

<h2 class="mb-3">Gestión de Repartidores</h2>

@if (_cargando)
{
    <p>Cargando...</p>
}
else
{
    <div class="edit-page">
        <h5 class="mt-2">Crear Nuevo Repartidor</h5>
        <div class="d-flex flex-column gap-2">
            <button class="btn btn-gradient-orange btn-full" @onclick="AbrirModalCrear">+ Nuevo repartidor</button>
        </div>
    </div>

    <hr class="my-4" />

    <h5 class="mb-2">Repartidores actuales</h5>

    @if (_repartidores.Count == 0)
    {
        <div class="alert alert-info">No hay repartidores registrados.</div>
    }
    else
    {
        @foreach (var r in _repartidores)
        {
            <div class="gp-card">
                <div class="gp-card-body" style="padding-top:10px">
                    <div class="gp-row align-items-center">
                        <span class="gp-label">Usuario</span>
                        <span>@r.NombreUsuario</span>
                    </div>
                    <div class="gp-row align-items-center">
                        <span class="gp-label">Nombre</span>
                        <span>@r.Nombre @r.Apellido</span>
                    </div>
                    <div class="gp-row align-items-center">
                        <span class="gp-label">Alta</span>
                        <span>@r.FechaAlta.ToLocalTime().ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="gp-row align-items-center">
                        <span class="gp-label">Estado</span>
                        <span class="chip @(r.Activo ? "chip-entregado" : "chip-cancelado")">@(r.Activo ? "Activo" : "Inactivo")</span>
                    </div>
                    <div class="gp-row align-items-center">
                        <span class="gp-label">Dispon.</span>
                        <select class="form-select form-select-sm" style="max-width:160px" value="@r.Disponibilidad"
                                @onchange="@(e => CambiarDisponibilidad(r, e.Value?.ToString()))">
                            <option value="Activo">Activo</option>
                            <option value="Ocupado">Ocupado</option>
                            <option value="Inactivo">Inactivo</option>
                        </select>
                    </div>
                </div>
                <div class="gp-card-actions">
                    <button class="btn btn-edit-orange gp-btn" @onclick="@(() => AbrirModalEditar(r))">Editar</button>
                    <button class="btn btn-gradient-red gp-btn" @onclick="@(() => AbrirModalEliminar(r))">Eliminar</button>
                </div>
            </div>
        }
    }

    <div class="catalog-footer-actions footer-safe-pad">
        <button class="btn btn-gradient-orange btn-full" @onclick="VolverPanel">
            Volver al panel de administrador
        </button>
        <button class="btn btn-gradient-red btn-full" @onclick="CerrarSesion">
            Cerrar sesión
        </button>
    </div>
}

@* Modal Crear/Editar *@
@if (_modalAbierto)
{
    <div class="modal-backdrop-custom" @onclick="CerrarModal"></div>
    <div class="modal-custom" role="dialog" @onclick:stopPropagation="true">
        <div class="modal-header">
            <h5 class="modal-title">@(_editando is null ? "Nuevo repartidor" : "Editar repartidor")</h5>
        </div>
        <div class="modal-body">
            @if (_editando is null)
            {
                <div class="mb-2">
                    <label class="form-label">ID de usuario</label>
                    <input type="number" class="form-control" @bind="_idUsuarioSeleccionado" placeholder="ID del usuario" />
                    <small class="text-muted">El usuario debe existir en el sistema.</small>
                </div>
            }
            <div class="mb-2">
                <label class="form-label">Nombre</label>
                <input class="form-control" @bind="_formNombre" />
            </div>
            <div class="mb-2">
                <label class="form-label">Apellido</label>
                <input class="form-control" @bind="_formApellido" />
            </div>
            <div class="mb-2">
                <label class="form-label">Disponibilidad</label>
                <select class="form-select" @bind="_formDisponibilidad">
                    <option value="Activo">Activo</option>
                    <option value="Ocupado">Ocupado</option>
                    <option value="Inactivo">Inactivo</option>
                </select>
            </div>
            <div class="mb-2 form-check">
                <input class="form-check-input" type="checkbox" @bind="_formActivo" id="chkActivo" />
                <label class="form-check-label" for="chkActivo">Activo en el sistema</label>
            </div>
            @if (_editando is not null)
            {
                <div class="mb-2">
                    <label class="form-label">Nueva contraseña <span class="text-muted">(opcional)</span></label>
                    <input type="password" class="form-control" @bind="_formNuevaPass" placeholder="Dejar vacío para no cambiar" />
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(_errorModal))
            {
                <div class="alert alert-danger mt-2">@_errorModal</div>
            }
        </div>
        <div class="modal-footer">
            <button class="btn btn-pill btn-grad-cancelar-modal" @onclick="CerrarModal" disabled="@_trabajando">Cancelar</button>
            <button class="btn btn-pill btn-grad-confirmar" @onclick="GuardarAsync" disabled="@_trabajando">
                @(_trabajando ? "Guardando..." : "Guardar")
            </button>
        </div>
    </div>
}

@* Modal Eliminar *@
@if (_modalEliminarAbierto)
{
    <div class="modal-backdrop-custom" @onclick="CerrarModalEliminar"></div>
    <div class="modal-custom" role="dialog" @onclick:stopPropagation="true">
        <div class="modal-header"><h5 class="modal-title">Eliminar repartidor</h5></div>
        <div class="modal-body">
            <p>¿Eliminar a <strong>@_repartidorAEliminar?.NombreUsuario</strong>? El usuario volverá al rol <em>cliente</em>.</p>
            @if (!string.IsNullOrWhiteSpace(_errorModal))
            {
                <div class="alert alert-danger">@_errorModal</div>
            }
        </div>
        <div class="modal-footer">
            <button class="btn btn-pill btn-grad-cancelar-modal" @onclick="CerrarModalEliminar" disabled="@_trabajando">Cancelar</button>
            <button class="btn btn-pill btn-gradient-red" @onclick="EliminarAsync" disabled="@_trabajando">
                @(_trabajando ? "Eliminando..." : "Eliminar")
            </button>
        </div>
    </div>
}

@* Toast *@
@if (_mostrarToast)
{
    <div class="app-toast">
        <div class="app-toast-body">
            <div class="app-toast-title">Éxito</div>
            @_toastText
        </div>
        <button class="app-toast-close" @onclick="CerrarToast">×</button>
    </div>
}

@code {
    private List<RepartidorService.RepartidorDto> _repartidores = new();
    private bool _cargando = true;

    private bool _modalAbierto;
    private bool _modalEliminarAbierto;
    private RepartidorService.RepartidorDto? _editando;
    private RepartidorService.RepartidorDto? _repartidorAEliminar;

    private int _idUsuarioSeleccionado;
    private string _formNombre = "";
    private string _formApellido = "";
    private string _formDisponibilidad = "Activo";
    private bool _formActivo = true;
    private string _formNuevaPass = "";
    private string? _errorModal;
    private bool _trabajando;

    private bool _mostrarToast;
    private string _toastText = "";
    private System.Timers.Timer? _toastTimer;

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.EstaLogueado || !Auth.EsAdmin)
        { Nav.NavigateTo("/login"); return; }

        await CargarAsync();
    }

    private async Task CargarAsync()
    {
        _cargando = true;
        _repartidores = await RepartidorSvc.GetTodosAsync();
        _cargando = false;
    }

    private void AbrirModalCrear()
    {
        _editando = null;
        _idUsuarioSeleccionado = 0;
        _formNombre = "";
        _formApellido = "";
        _formDisponibilidad = "Activo";
        _formActivo = true;
        _formNuevaPass = "";
        _errorModal = null;
        _modalAbierto = true;
    }

    private void AbrirModalEditar(RepartidorService.RepartidorDto r)
    {
        _editando = r;
        _formNombre = r.Nombre ?? "";
        _formApellido = r.Apellido ?? "";
        _formDisponibilidad = r.Disponibilidad;
        _formActivo = r.Activo;
        _formNuevaPass = "";
        _errorModal = null;
        _modalAbierto = true;
    }

    private void AbrirModalEliminar(RepartidorService.RepartidorDto r)
    {
        _repartidorAEliminar = r;
        _errorModal = null;
        _modalEliminarAbierto = true;
    }

    private void CerrarModal() { _modalAbierto = false; _errorModal = null; _trabajando = false; }
    private void CerrarModalEliminar() { _modalEliminarAbierto = false; _errorModal = null; _trabajando = false; }

    private async Task CambiarDisponibilidad(RepartidorService.RepartidorDto r, string? nueva)
    {
        if (string.IsNullOrWhiteSpace(nueva)) return;
        await RepartidorSvc.CambiarDisponibilidadAsync(r.Id, nueva);
        r.Disponibilidad = nueva;
    }

    private async Task GuardarAsync()
    {
        _trabajando = true;
        _errorModal = null;

        bool ok;
        if (_editando is null)
        {
            if (_idUsuarioSeleccionado == 0)
            { _errorModal = "Ingresá el ID del usuario."; _trabajando = false; return; }

            ok = await RepartidorSvc.CrearAsync(new RepartidorService.RepartidorRequest
            {
                IdUsuario = _idUsuarioSeleccionado,
                Nombre = _formNombre.Trim(),
                Apellido = _formApellido.Trim(),
                Disponibilidad = _formDisponibilidad,
                Activo = _formActivo
            });
        }
        else
        {
            ok = await RepartidorSvc.ActualizarAsync(_editando.Id, new RepartidorService.RepartidorRequest
            {
                IdUsuario = _editando.IdUsuario,
                Nombre = _formNombre.Trim(),
                Apellido = _formApellido.Trim(),
                Disponibilidad = _formDisponibilidad,
                Activo = _formActivo
            });
        }

        _trabajando = false;
        if (ok)
        {
            if (_editando is not null && !string.IsNullOrWhiteSpace(_formNuevaPass))
            {
                var okPass = await AdminSvc.CambiarContrasenaAsync(_editando.IdUsuario, _formNuevaPass.Trim());
                if (!okPass) { _errorModal = "Repartidor actualizado, pero no se pudo cambiar la contraseña."; return; }
            }
            CerrarModal();
            MostrarToast(_editando is null ? "Repartidor creado." : "Repartidor actualizado.");
            await CargarAsync();
        }
        else
        {
            _errorModal = "No se pudo guardar. Verificá el ID de usuario.";
        }
    }

    private async Task EliminarAsync()
    {
        if (_repartidorAEliminar is null) return;
        _trabajando = true;
        var ok = await RepartidorSvc.EliminarAsync(_repartidorAEliminar.Id);
        _trabajando = false;
        if (ok)
        {
            CerrarModalEliminar();
            MostrarToast("Repartidor eliminado.");
            await CargarAsync();
        }
        else
        {
            _errorModal = "No se pudo eliminar.";
        }
    }

    private void MostrarToast(string texto)
    {
        _toastText = texto;
        _mostrarToast = true;
        StateHasChanged();
        _toastTimer?.Stop();
        _toastTimer = new System.Timers.Timer(2200) { AutoReset = false };
        _toastTimer.Elapsed += (_, __) => { _mostrarToast = false; InvokeAsync(StateHasChanged); };
        _toastTimer.Start();
    }
    private void CerrarToast() { _mostrarToast = false; _toastTimer?.Stop(); }
    private void VolverPanel() => Nav.NavigateTo("/paneladmin");
    private void CerrarSesion() { Auth.Logout(); Nav.NavigateTo("/login", true); }
    public void Dispose() { _toastTimer?.Stop(); _toastTimer?.Dispose(); }
}
