@page "/gestionadministradores"
@inject MauiBlazorDelivery.Services.AuthService Auth
@inject MauiBlazorDelivery.Services.AdminService AdminSvc
@using MauiBlazorDelivery.Services
@inject NavigationManager Nav

<h2 class="mb-3">Gestión de Administradores</h2>

@if (!string.IsNullOrEmpty(_loadError))
{
    <div class="alert alert-danger">@_loadError</div>
}

@if (Cargando)
{
    <Spinner />
}
else
{
    @* crear nuevo (usa .edit-page y botón ancho .btn-full del css global) *@
    <form class="edit-page" @onsubmit="AbrirConfirmCrear" @onsubmit:preventDefault>
        <h5 class="mt-2">Crear Nuevo Administrador</h5>

        <div class="mb-2">
            <label class="form-label">NombreUsuario</label>
            <InputText class="form-control" @bind-Value="NuevoNombre" />
        </div>
        <div class="mb-3">
            <label class="form-label">Contraseña</label>
            <input type="password" class="form-control" @bind="NuevaPass" />
        </div>

        <div class="d-flex flex-column gap-2">
            <button type="submit" class="btn btn-gradient-orange btn-full">Crear Administrador</button>
        </div>
    </form>

    <hr class="my-4" />

    <h5 class="mb-2">Administradores actuales</h5>

    @if (Admins is null || Admins.Count == 0)
    {
        <div class="alert alert-info">No hay administradores registrados.</div>
    }
    else
    {
        @foreach (var a in Admins)
        {
            var enEdicion = EditandoId == a.Id;
            <div class="gp-card">
                <div class="gp-card-body" style="padding-top:10px">
                    <div class="gp-row align-items-center">
                        <span class="gp-label">Usuario</span>
                        @if (enEdicion)
                        {
                            <InputText class="form-control form-control-sm" @bind-Value="a.NombreUsuario" />
                        }
                        else
                        {
                            <span>@a.NombreUsuario</span>
                        }
                    </div>
                    <div class="gp-row align-items-center">
                        <span class="gp-label">Contraseña</span>
                        @if (enEdicion)
                        {
                            <input type="password" class="form-control form-control-sm" @bind="_nuevaPassEdicion" placeholder="Nueva contraseña (opcional)" />
                        }
                        else
                        {
                            <span>******</span>
                        }
                    </div>
                </div>
                <div class="gp-card-actions">
                    @if (enEdicion)
                    {
                        <button class="btn btn-gradient-green gp-btn" @onclick="() => GuardarFilaAsync(a)">Guardar</button>
                        <button class="btn btn-gradient-orange gp-btn" @onclick="() => CancelarEdicion(a)">Cancelar</button>
                    }
                    else
                    {
                        <button class="btn btn-edit-orange gp-btn" @onclick="() => Editar(a)">Editar</button>
                        <button class="btn btn-gradient-red gp-btn" @onclick="() => ConfirmarEliminar(a)">Eliminar</button>
                    }
                </div>
            </div>
        }
    }

    @* botones inferiores anchos y consistentes *@
    <div class="catalog-footer-actions footer-safe-pad">
        <button class="btn btn-gradient-orange btn-full" @onclick="VolverPanel">
            Volver al panel de administrador
        </button>

        <button class="btn btn-gradient-red btn-full" @onclick="CerrarSesion">
            Cerrar sesión
        </button>
    </div>
}

@* ------- Modal confirmar CREAR (usa clases globales de modal) ------- *@
@if (MostrarConfirmacionCrear)
{
    <div class="modal-backdrop-custom" @onclick="CerrarModalCrear"></div>
    <div class="modal-custom" role="dialog" aria-modal="true" @onclick:stopPropagation="true">
        <div class="modal-header">
            <h5 class="modal-title">Confirmar creación</h5>
        </div>
        <div class="modal-body">
            <p>¿Estás seguro de crear al administrador <strong>@NuevoNombre</strong>?</p>
            @if (!string.IsNullOrEmpty(ErrorMsgCrear))
            {
                <div class="alert alert-danger mt-2">@ErrorMsgCrear</div>
            }
        </div>
        <div class="modal-footer">
            <button class="btn btn-pill btn-grad-cancelar-modal" @onclick="CerrarModalCrear">No, cancelar</button>
            <button class="btn btn-pill btn-grad-confirmar" @onclick="CrearAdminConfirmadoAsync">Sí, crear</button>
        </div>
    </div>
}

@* ------- Modal confirmar ELIMINAR (usa clases globales de modal) ------- *@
@if (MostrarConfirmacionEliminar)
{
    <div class="modal-backdrop-custom" @onclick="CerrarModalEliminar"></div>
    <div class="modal-custom" role="dialog" aria-modal="true" @onclick:stopPropagation="true">
        <div class="modal-header">
            <h5 class="modal-title">Confirmar eliminación</h5>
        </div>
        <div class="modal-body">
            <p>¿Eliminar al administrador <strong>@AdminAEliminar?.NombreUsuario</strong>?</p>
            @if (!string.IsNullOrEmpty(ErrorMsgEliminar))
            {
                <div class="alert alert-danger mt-2">@ErrorMsgEliminar</div>
            }
        </div>
        <div class="modal-footer">
            <button class="btn btn-pill btn-grad-cancelar-modal" @onclick="CerrarModalEliminar">No, cancelar</button>
            <button class="btn btn-pill btn-grad-confirmar" @onclick="EliminarConfirmadoAsync">Sí, eliminar</button>
        </div>
    </div>
}

@if (_mostrarToast)
{
    <div class="app-toast">
        <div class="app-toast-body">
            <div class="app-toast-title">@_toastTitulo</div>
            @_toastText
        </div>
        <button class="app-toast-close" @onclick="CerrarToast">×</button>
    </div>
}

@code {
    private bool Cargando = true;
    private string? _loadError;

    // Crear nuevo
    private string NuevoNombre = string.Empty;
    private string NuevaPass = string.Empty;

    // Listado y edición
    private List<AdminService.AdminDto> Admins = new();
    private int? EditandoId = null;
    private AdminService.AdminDto? BackupEdicion;
    private string _nuevaPassEdicion = "";

    // Confirmaciones
    private bool MostrarConfirmacionCrear = false;
    private string? ErrorMsgCrear;
    private bool MostrarConfirmacionEliminar = false;
    private AdminService.AdminDto? AdminAEliminar;
    private string? ErrorMsgEliminar;

    private bool _mostrarToast;
    private string _toastTitulo = "";
    private string _toastText = "";
    private System.Timers.Timer? _toastTimer;

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.EstaLogueado || !Auth.EsAdmin)
        {
            Nav.NavigateTo("/login");
            return;
        }
        await CargarAsync();
    }

    private async Task CargarAsync()
    {
        try
        {
            Cargando = true;
            _loadError = null;
            Admins = await AdminSvc.GetAdminsAsync();
        }
        catch (Exception ex)
        {
            _loadError = $"No se pudieron cargar los administradores: {ex.Message}";
            Console.WriteLine(ex);
        }
        finally
        {
            Cargando = false;
            StateHasChanged();
        }
    }

    /* ===== Crear con confirmación + toast ===== */
    private void AbrirConfirmCrear()
    {
        ErrorMsgCrear = null;
        if (string.IsNullOrWhiteSpace(NuevoNombre) || string.IsNullOrWhiteSpace(NuevaPass))
        {
            MostrarToast("Atención", "Completá usuario y contraseña.");
            return;
        }
        MostrarConfirmacionCrear = true;
        StateHasChanged();
    }

    private void CerrarModalCrear()
    {
        MostrarConfirmacionCrear = false;
        ErrorMsgCrear = null;
        StateHasChanged();
    }

    private async Task CrearAdminConfirmadoAsync()
    {
        try
        {
            ErrorMsgCrear = null;

            var ok = await AdminSvc.CrearAsync(new(NuevoNombre.Trim(), NuevaPass.Trim()));
            if (ok)
            {
                MostrarConfirmacionCrear = false;
                NuevoNombre = NuevaPass = string.Empty;
                await CargarAsync();
                MostrarToast("Éxito", "Administrador creado correctamente.");
            }
            else
            {
                ErrorMsgCrear = "No se pudo crear el administrador.";
            }
        }
        catch (Exception ex)
        {
            ErrorMsgCrear = $"Error: {ex.Message}";
        }
        finally
        {
            StateHasChanged();
        }
    }

    /* ===== Editar / Guardar / Cancelar con toast ===== */
    private void Editar(AdminService.AdminDto a)
    {
        EditandoId = a.Id;
        _nuevaPassEdicion = "";
        BackupEdicion = new AdminService.AdminDto
        {
            Id = a.Id,
            NombreUsuario = a.NombreUsuario
        };
        StateHasChanged();
    }

    private void CancelarEdicion(AdminService.AdminDto a)
    {
        if (BackupEdicion != null && BackupEdicion.Id == a.Id)
            a.NombreUsuario = BackupEdicion.NombreUsuario;
        EditandoId = null;
        BackupEdicion = null;
        _nuevaPassEdicion = "";
        StateHasChanged();
    }

    private async Task GuardarFilaAsync(AdminService.AdminDto a)
    {
        if (string.IsNullOrWhiteSpace(a.NombreUsuario))
        {
            MostrarToast("Atención", "El nombre de usuario no puede estar vacío.");
            return;
        }

        a.NombreUsuario = a.NombreUsuario.Trim();

        var ok = await AdminSvc.ActualizarAsync(a);
        if (!ok) { MostrarToast("Error", "No se pudo actualizar el usuario."); return; }

        if (!string.IsNullOrWhiteSpace(_nuevaPassEdicion))
        {
            var okPass = await AdminSvc.CambiarContrasenaAsync(a.Id, _nuevaPassEdicion.Trim());
            if (!okPass) { MostrarToast("Error", "Usuario actualizado, pero no se pudo cambiar la contraseña."); return; }
        }

        EditandoId = null;
        BackupEdicion = null;
        _nuevaPassEdicion = "";
        MostrarToast("Éxito", "Administrador actualizado.");
    }

    /* ===== Eliminar con confirmación modal + toast ===== */
    private void ConfirmarEliminar(AdminService.AdminDto a)
    {
        AdminAEliminar = a;
        ErrorMsgEliminar = null;
        MostrarConfirmacionEliminar = true;
        StateHasChanged();
    }

    private void CerrarModalEliminar()
    {
        MostrarConfirmacionEliminar = false;
        AdminAEliminar = null;
        ErrorMsgEliminar = null;
        StateHasChanged();
    }

    private async Task EliminarConfirmadoAsync()
    {
        if (AdminAEliminar is null) return;

        var ok = await AdminSvc.EliminarAsync(AdminAEliminar.Id);
        MostrarConfirmacionEliminar = false;

        if (ok)
        {
            MostrarToast("Éxito", "Administrador eliminado correctamente.");
            await CargarAsync();
        }
        else
        {
            MostrarToast("Error", "No se pudo eliminar el administrador.");
        }
    }

    private void MostrarToast(string titulo, string texto)
    {
        _toastTitulo = titulo;
        _toastText = texto;
        _mostrarToast = true;
        StateHasChanged();

        _toastTimer?.Stop();
        _toastTimer = new System.Timers.Timer(3000) { AutoReset = false };
        _toastTimer.Elapsed += (_, __) => { _mostrarToast = false; InvokeAsync(StateHasChanged); };
        _toastTimer.Start();
    }

    private void CerrarToast()
    {
        _mostrarToast = false;
        _toastTimer?.Stop();
        StateHasChanged();
    }

    /* ===== Nav / Auth ===== */
    private void VolverPanel() => Nav.NavigateTo("/paneladmin");
    private void CerrarSesion()
    {
        Auth.Logout();
        Nav.NavigateTo("/login", true);
    }
}
