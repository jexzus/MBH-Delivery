@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject MauiBlazorDelivery.Services.AuthService AuthService
@inject MauiBlazorDelivery.Services.SignalRService SignalR
@inject MauiBlazorDelivery.Services.NotificationService Notif
@implements IDisposable

@code {
    string Path => new Uri(Nav.Uri).AbsolutePath;
    bool Starts(string prefix) => Path.StartsWith(prefix, StringComparison.OrdinalIgnoreCase);

    bool IsAuthPage => Starts("/login") || Starts("/registro");

    bool IsAdminWorkspace =>
        Starts("/paneladmin") ||
        Starts("/panelrepartidor") ||
        Starts("/panelvendedor") ||
        Starts("/gestioncatalogo") ||
        Starts("/gestionpedidos") ||
        Starts("/gestionadministradores") ||
        Starts("/gestionvendedores") ||
        Starts("/gestionrepartidores") ||
        Starts("/editarproducto") ||
        Starts("/admin/producto/editar") ||
        Starts("/nuevoproducto") ||
        Starts("/admin/producto/nuevo");

    bool IsClientWorkspace =>
        Starts("/catalogo") ||
        Starts("/carrito") ||
        Starts("/estadopedido");

    bool ShowTopbar => !IsAuthPage && !IsAdminWorkspace && !IsClientWorkspace;

    private bool _notifSubscribed = false;

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += OnLocationChanged;
        await TrySubscribeNotifAsync();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
        => _ = TrySubscribeNotifAsync();

    private async Task TrySubscribeNotifAsync()
    {
        if (_notifSubscribed || !AuthService.EstaLogueado) return;

        await Notif.PedirPermisoAsync();

        if (AuthService.EsCliente)
            SignalR.EstadoCambiadoGlobal += OnEstadoCambiadoCliente;

        if (AuthService.EsRepartidor)
            SignalR.NuevoPedidoParaReparto += OnNuevoPedidoRepartidor;

        Notif.NotificacionTocada += OnNotificacionTocada;
        _notifSubscribed = true;
    }

    private void OnNotificacionTocada(string data)
    {
        InvokeAsync(() =>
        {
            if (data == "cliente")
                Nav.NavigateTo("/estadopedido");
            else if (data == "repartidor")
                Nav.NavigateTo("/panelrepartidor");
        });
    }

    private void OnEstadoCambiadoCliente(int numPedido, string nuevoEstado)
    {
        var etiqueta = nuevoEstado == "EsperandoRepartidor" ? "Buscando repartidor" : nuevoEstado;
        Notif.Mostrar("Tu pedido fue actualizado", $"Pedido #{numPedido} → {etiqueta}", "cliente");
    }

    private void OnNuevoPedidoRepartidor(SignalRService.NuevoPedidoDto dto)
    {
        Notif.Mostrar("🛵 Nueva solicitud de reparto",
            $"Pedido #{dto.NumPedido} — {dto.Cliente} · ${dto.MontoTotal}", "repartidor");
    }

    void CerrarSesion()
    {
        AuthService.Logout();
        Nav.NavigateTo("/login", true);
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
        SignalR.EstadoCambiadoGlobal -= OnEstadoCambiadoCliente;
        SignalR.NuevoPedidoParaReparto -= OnNuevoPedidoRepartidor;
        Notif.NotificacionTocada -= OnNotificacionTocada;
    }
}

<div class="page">
    @if (!IsAuthPage)
    {
        <div class="sidebar">
            <NavMenu />
        </div>
    }

    <main class="@(IsAuthPage ? "auth-main w-100" : "")">
        @if (ShowTopbar)
        {
            <div class="top-row px-4">
                <button @onclick="CerrarSesion" style="margin-left:20px;">Cerrar Sesión</button>
            </div>
        }

        <article class="content @(IsAuthPage ? "" : "px-4")">
            @Body
        </article>
    </main>
</div>
